{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "tracker.palmvolley.com" }],
      "destination": "https://tracker.palmvolleypickle.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/i/:token",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
